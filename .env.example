#KUBECONFIG_OVERRIDE=~/.kube/config
# KUBE_CONTEXT=my-cluster
# KUBE_CTX=my-cluster
LOG_LEVEL=DEBUG
LOG_FORMAT=logfmt
DRY_RUN=1
# NODE_LABEL_SELECTOR=karpenter.sh/capacity-type=spot
# NODE_DISRUPTION_CORDONED=1        # 1 = treat unschedulable (cordoned) nodes as disrupted
# NODE_DISRUPTION_TAINTS=karpenter.sh/disrupted  # comma-separated taint keys to treat as disruption
# NODE_EVENT_REASONS=DisruptionBlocked            # comma-separated Kubernetes Event reasons to react to
# NODE_EVENT_TAINT=disruption-rollout-controller/disrupted:NoSchedule  # taint to apply to the node on event match (key:Effect or key=value:Effect)
# NODE_EVENT_TAINT_REMOVE=0                           # set to 1 to remove the taint after rollout is triggered
# At least one of NODE_DISRUPTION_CORDONED, NODE_DISRUPTION_TAINTS, NODE_EVENT_REASONS must be set
# POD_LABEL_SELECTOR=app=myapp,env=production
# POD_ANNOTATION_SELECTOR=discruption-rollout=true
# ALLOWED_NAMESPACES=default,production
