#KUBECONFIG_OVERRIDE=~/.kube/config
# KUBE_CONTEXT=my-cluster
# KUBE_CTX=my-cluster
LOG_LEVEL=DEBUG
LOG_FORMAT=logfmt
DRY_RUN=1
# NODE_LABEL_SELECTOR=karpenter.sh/capacity-type=spot
# NODE_DISRUPTION_CORDONED=1        # 1 = treat unschedulable (cordoned) nodes as disrupted
# NODE_DISRUPTION_TAINTS=karpenter.sh/disrupted  # comma-separated taint keys to treat as disruption
# At least one of the above must be set
# POD_LABEL_SELECTOR=app=myapp,env=production
# POD_ANNOTATION_SELECTOR=discruption-rollout=true
# ALLOWED_NAMESPACES=default,production
